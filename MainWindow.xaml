<Window x:Class="TouchpadToMiddleClick.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SolidWorks 触摸板驱动控制台" Height="250" Width="400"
        WindowStartupLocation="CenterScreen">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

        <TextBlock x:Name="wadpy_pn_StatusText" 
                   Text="当前状态：驱动未开启 ⏸️" 
                   FontSize="18" 
                   FontWeight="Bold" 
                   Foreground="Gray" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,30"/>

        <Button x:Name="wadpy_pn_ToggleButton" 
                Content="开启终极丝滑驱动 (快捷键: Alt+Shift+M)" 
                FontSize="16" 
                Width="317" Height="50" 
                Click="wadpy_pn_ToggleButton_Click"/>

    </StackPanel>
</Window>