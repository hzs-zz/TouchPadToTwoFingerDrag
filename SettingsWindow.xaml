<ui:FluentWindow x:Name="wadpy_pn_RootWindow"
        x:Class="TouchpadToMiddleClick.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="驱动控制中心" Height="480" Width="720"
        WindowStartupLocation="CenterScreen" 
        ExtendsContentIntoTitleBar="True" 
        WindowBackdropType="Mica"
        Foreground="Black">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="SolidWorks 触摸板驱动控制中心" />

        <TabControl Grid.Row="1" Margin="10,0,10,10" TabStripPlacement="Left" Background="Transparent" BorderThickness="0">

            <TabItem Header="🎯 目标进程" FontSize="15" Margin="0,0,0,8">
                <StackPanel Margin="30">
                    <TextBlock Text="智能焦点追踪" FontSize="20" FontWeight="Bold" Margin="0,0,0,5" Foreground="Black"/>
                    <TextBlock Text="输入进程名（如 Notepad）后点击添加或按回车：" Foreground="#66000000" Margin="0,0,0,15"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <ui:TextBox x:Name="wadpy_pn_ProcessInput" PlaceholderText="例如: SLDWORKS" Width="220" Margin="0,0,10,0" KeyDown="wadpy_pn_ProcessInput_KeyDown"/>
                        <ui:Button Content="添加" Icon="{ui:SymbolIcon Add24}" Appearance="Primary" Click="wadpy_pn_AddButton_Click"/>
                    </StackPanel>

                    <ui:Card Padding="10">
                        <ListBox x:Name="wadpy_pn_ProcessList" Height="160" Background="Transparent" BorderThickness="0" ItemsSource="{Binding}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="280">
                                        <TextBlock Text="{Binding}" VerticalAlignment="Center" Foreground="Black" FontSize="14"/>
                                        <ui:Button Icon="{ui:SymbolIcon Delete24}" Appearance="Transparent" HorizontalAlignment="Right" Click="wadpy_pn_DeleteButton_Click" ToolTip="移除此进程"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ui:Card>
                </StackPanel>
            </TabItem>

            <TabItem Header="☕ 捐赠支持" FontSize="15" Margin="0,0,0,8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30" HorizontalAlignment="Center">
                        <TextBlock Text="请作者喝杯咖啡" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Black" Margin="0,0,0,30"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <ui:Card Margin="10">
                                <Image Source="wechat_pay.png" Width="150" Height="150" Stretch="Uniform"/>
                            </ui:Card>
                            <ui:Card Margin="10">
                                <Image Source="alipay.png" Width="150" Height="150" Stretch="Uniform"/>
                            </ui:Card>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="👨‍💻 贡献者" FontSize="15" Margin="0,0,0,8">
                <StackPanel Margin="30" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="80" Height="80" Margin="0,0,0,15">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="avatar.png" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="Huang Zisheng" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Black"/>
                    <ui:Button Content="GitHub" Icon="{ui:SymbolIcon Code24}" Appearance="Secondary" Margin="0,20,0,0" Click="GithubButton_Click"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</ui:FluentWindow>