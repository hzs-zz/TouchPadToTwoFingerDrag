<ui:FluentWindow x:Name="wadpy_pn_RootWindow"
        x:Class="TouchpadToMiddleClick.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="驱动控制中心" Height="500" Width="750"
        WindowStartupLocation="CenterScreen" 
        ExtendsContentIntoTitleBar="True" 
        WindowBackdropType="Mica"
        Foreground="Black">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="触摸板接管manager" Padding="10,0" />

        <TabControl Grid.Row="1" Margin="5,10,5,5" TabStripPlacement="Left" Background="Transparent" BorderThickness="0">

            <TabItem Header="目标进程" FontSize="15" Margin="0,0,0,8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="25">
                        <TextBlock Text="智能焦点追踪" FontSize="22" FontWeight="Bold" Margin="0,0,0,5" Foreground="Black"/>
                        <TextBlock Text="当下列程序获得焦点时，驱动将自动接管系统滚动。" Foreground="#88000000" Margin="0,0,0,25"/>

                        <ui:Card Padding="15" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="添加新进程" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="Black"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <ui:SymbolIcon Symbol="Target24" Grid.Column="0" Margin="0,0,12,0" Foreground="{ui:ThemeResource SystemAccentColorPrimaryBrush}"/>

                                    <ui:TextBox x:Name="wadpy_pn_ProcessInput" 
                                                Grid.Column="1"
                                                PlaceholderText="输入进程名 (例如: SLDWORKS)" 
                                                Icon="{ui:SymbolIcon Search24}"
                                                KeyDown="wadpy_pn_ProcessInput_KeyDown"/>

                                    <ui:Button Grid.Column="2" 
                                               Content="添加名单" 
                                               Margin="10,0,0,0"
                                               Icon="{ui:SymbolIcon Add24}" 
                                               Appearance="Primary" 
                                               Padding="15,6"
                                               Click="wadpy_pn_AddButton_Click"/>
                                </Grid>
                            </StackPanel>
                        </ui:Card>

                        <TextBlock Text="当前受控名单" FontWeight="SemiBold" Margin="5,0,0,10" Foreground="Black"/>
                        <ui:Card Padding="5">
                            <ListBox x:Name="wadpy_pn_ProcessList" 
                                     MinHeight="180" 
                                     Background="Transparent" 
                                     BorderThickness="0" 
                                     ItemsSource="{Binding}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#11000000" BorderThickness="0,0,0,1" Padding="10,8">
                                            <Grid>
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="Document24" Margin="0,0,12,0" Foreground="#55000000"/>
                                                    <TextBlock Text="{Binding}" VerticalAlignment="Center" Foreground="Black" FontSize="14"/>
                                                </StackPanel>

                                                <ui:Button Icon="{ui:SymbolIcon Delete24}" 
                                                           Appearance="Transparent" 
                                                           HorizontalAlignment="Right" 
                                                           Foreground="#CCFF4444"
                                                           Click="wadpy_pn_DeleteButton_Click" 
                                                           ToolTip="从名单中移除"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ui:Card>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="捐赠支持" FontSize="15" Margin="0,0,0,8">
                <StackPanel Margin="30" HorizontalAlignment="Center">
                    <TextBlock Text="请作者喝杯咖啡" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Black" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <ui:Card Margin="10">
                            <Image Source="wechat_pay.png" Width="160" Height="160" Stretch="Uniform"/>
                        </ui:Card>
                        <ui:Card Margin="10">
                            <Image Source="alipay.png" Width="160" Height="160" Stretch="Uniform"/>
                        </ui:Card>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <TabItem Header="Contributor" FontSize="15" Margin="0,0,0,8">
                <StackPanel Margin="30" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="80" Height="80" Margin="0,0,0,15">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="avatar.png" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="Huang Zisheng" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Black"/>
                    <ui:Button Content="GitHub" Icon="{ui:SymbolIcon Code24}" Appearance="Secondary" Margin="0,20,0,0" Click="GithubButton_Click"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </Grid>
</ui:FluentWindow>